{
  "name": "vortex",
  "version": "0.1.0",
  "description": "Private torrent dashboard and desktop launcher.",
  "author": "Anindya",
  "type": "module",
  "private": true,
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "next dev",
    "server": "node server.mjs",
    "dev:full": "concurrently \"npm run dev\" \"npm run server\"",
    "build:engine:exe": "node build-engine.mjs",
    "desktop": "electron .",
    "build:desktop": "npm run build:engine:exe && electron-builder --win nsis",
    "build:desktop:dir": "npm run build:engine:exe && electron-builder --win dir",
    "build:electron": "electron-builder --win nsis",
    "build:electron:dir": "electron-builder --win dir",
    "build:electron:portable": "electron-builder --win portable",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "auto-launch": "^5.0.6",
    "axios": "^1.13.6",
    "body-parser": "^2.2.2",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "electron-is-dev": "^3.0.1",
    "express": "^5.2.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "torrent-search-api": "^2.1.4",
    "webtorrent": "^1.9.7"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@yao-pkg/pkg": "^6.14.1",
    "autoprefixer": "^10.4.19",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9",
    "eslint-config-next": "15.1.0",
    "pkg": "^5.8.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.38",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.vortex.desktop",
    "productName": "Vortex",
    "icon": "public/icon.ico",
    "asar": true,
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "!**/node_modules/**"
    ],
    "extraResources": [
      {
        "from": "public/downloads/vortex.exe",
        "to": "engine/vortex.exe"
      },
      {
        "from": "public/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico",
      "artifactName": "Vortex-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vortex"
    }
  }
}