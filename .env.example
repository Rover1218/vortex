# ─── Firebase (client) — safe to expose, used by the browser ───
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin (server only — NEVER prefix with NEXT_PUBLIC_) ───
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Premium / Payments ───
# Public base URL of the deployed dashboard, e.g. https://vortex.example.com
NEXT_PUBLIC_APP_URL=

# Your own Firebase Auth UID — unlocks the /admin page and admin API actions.
# NEXT_PUBLIC_ADMIN_UID only controls UI visibility; ADMIN_UID is what the
# server actually enforces. Set both to the same UID.
ADMIN_UID=
NEXT_PUBLIC_ADMIN_UID=

# Dodo Payments (dashboard → Developer → API Keys / Webhooks)
# Use https://test.dodopayments.com while testing, https://live.dodopayments.com in production.
DODO_API_BASE=https://test.dodopayments.com
DODO_API_KEY=
DODO_WEBHOOK_SECRET=

# Product IDs of the three plans created in the Dodo dashboard
DODO_PRODUCT_MONTHLY=
DODO_PRODUCT_HALFYEAR=
DODO_PRODUCT_LIFETIME=
