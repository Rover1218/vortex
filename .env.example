# ─── Firebase (client) — safe to expose, used by the browser ───
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin (server only — NEVER prefix with NEXT_PUBLIC_) ───
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Premium / Payments ───
# Public base URL of the deployed dashboard, e.g. https://vortex.example.com
NEXT_PUBLIC_APP_URL=

# Your own Firebase Auth UID — unlocks the /admin page, admin API actions, and
# the leaderboard. NEXT_PUBLIC_ADMIN_UID only controls UI visibility; ADMIN_UID
# is what the server actually enforces. Set both to the same UID.
ADMIN_UID=
NEXT_PUBLIC_ADMIN_UID=

# Razorpay (dashboard → Account & Settings → API Keys / Webhooks)
# Use rzp_test_* keys while testing, rzp_live_* keys in production.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook: subscribe https://<domain>/api/premium/webhook to `payment.captured`
RAZORPAY_WEBHOOK_SECRET=
